# devforge: regenerable inner-loop transients (re-created from git diff / re-running
# the oracle). Durable records (task.md, design.md, review.md, progress.md, state.json,
# claim.md, *.approved) are committed on the feature branch as the evidence trail.
.devforge/iter-*/diff.patch
.devforge/iter-*/test-results.txt

# Local/generated devforge config. The shipped defaults live beside the skill.
.devforge/config.json
.devforge/config.schema.json

# Per-environment stage overrides (e.g. pointing a stage at a locally-installed skill).
.devforge/config.local.json

# Editor / OS noise
.idea/
.DS_Store

# Python build artifacts (from dogfooding the loop in this repo)
__pycache__/
*.pyc
.pytest_cache/
