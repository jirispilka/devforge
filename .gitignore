# devforge regenerates these inner-loop artifacts from git diff and oracle runs.
# Durable evidence files remain tracked with the feature branch.
.devforge/iter-*/diff.patch
.devforge/iter-*/test-results.txt

# Local/generated config; shipped defaults live beside the skill.
.devforge/config.json
.devforge/config.schema.json

# Per-environment stage overrides, such as pointing a stage at a local skill.
.devforge/config.local.json

# Editor and OS noise
.idea/
.DS_Store

# Python artifacts from local tests
__pycache__/
*.pyc
.pytest_cache/
